{
	"$schema": "https://www.schemastore.org/package.json",
	"name": "@ozanarslan/corpus",
	"version": "0.5.4",
	"description": "Small Typescript backend framework with only core utilities",
	"keywords": [
		"backend framework",
		"bun serve",
		"simple"
	],
	"homepage": "https://corpus-production.up.railway.app/",
	"bugs": {
		"url": "https://github.com/ozanArslan2424/corpus.git/issues"
	},
	"license": "MIT",
	"author": "Ozan Arslan <ozanarslanwork@gmail.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ozanArslan2424/corpus.git"
	},
	"files": [
		"dist",
		"LICENSE.txt",
		"THIRD_PARTY_LICENSES.txt"
	],
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "bun run build.ts",
		"test:serve": "bun run test/other/test-server.ts",
		"test:http": "bun run test/other/http-simulation.ts",
		"test:ws": "bun run test/other/ws-simulation.ts",
		"test:benchmark": "bun run test/other/benchmark.ts",
		"test:all": "bun run build && bun test --only-failures && bun test:http -s && bun test:ws -s && bun test:benchmark",
		"tests": "pnpm run build && bun test --only-failures"
	},
	"devDependencies": {
		"arktype": "^2.2.0",
		"bun-plugin-dts": "^0.4.0",
		"corpus-utils": "workspace:*",
		"memoirist": "^0.4.0",
		"zod": "^4.3.6"
	},
	"peerDependencies": {
		"typescript": "^6.0.2"
	}
}
