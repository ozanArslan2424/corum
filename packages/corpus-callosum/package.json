{
	"$schema": "https://www.schemastore.org/package.json",
	"name": "@ozanarslan/corpus-callosum",
	"version": "0.5.4",
	"description": "CLI for @ozanarslan/corpus",
	"license": "MIT",
	"author": "Ozan Arslan <ozanarslanwork@gmail.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ozanArslan2424/corpus.git",
		"directory": "packages/corpus-callosum"
	},
	"bin": {
		"corpus": "dist/index.mjs"
	},
	"files": [
		"dist",
		"LICENSE.txt"
	],
	"type": "module",
	"exports": {
		".": "./dist/index.mjs",
		"./config": "./dist/config.mjs",
		"./generateApiClient/ApiClientGenerator": "./dist/generateApiClient/ApiClientGenerator.mjs",
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsdown",
		"test:api": "bun run build && bun run ./dist/index.mjs api -s -m ./test/other/startServer.ts -o ./test/other/generated.ts && bun run ./test/other/integration.ts -s",
		"test:all": "bun test --only-failures && bun test:api",
		"tests": "bun test --only-failures"
	},
	"dependencies": {
		"@clack/prompts": "^1.2.0",
		"@sodaru/yup-to-json-schema": "^2.0.1",
		"@standard-community/standard-json": "^0.3.5",
		"@standard-schema/spec": "^1.1.0",
		"json-schema-to-typescript": "^15.0.4",
		"prettier": "^3.8.3",
		"typescript": "^6.0.2"
	},
	"devDependencies": {
		"@ozanarslan/corpus": "workspace:*",
		"arktype": "^2.2.0",
		"corpus-utils": "workspace:*",
		"tsdown": "^0.21.9",
		"yup": "^1.7.1",
		"zod": "^4.3.6"
	},
	"inlinedDependencies": {
		"zod": "4.3.6"
	}
}
