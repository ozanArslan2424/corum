{
	"name": "@ozanarslan/corpus",
	"type": "module",
	"version": "0.1.19",
	"description": "Small Typescript backend framework with only core utilities",
	"author": "Ozan Arslan <ozanarslanwork@gmail.com>",
	"license": "MIT",
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"homepage": "https://corpus-production.up.railway.app/",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ozanArslan2424/corpus.git"
	},
	"keywords": [
		"bun serve",
		"backend framework",
		"simple"
	],
	"scripts": {
		"fm": "bunx --bun prettier --write .",
		"lint": "bunx oxlint -c ./.oxlintrc.json --fix",
		"build": "bun run build.ts",
		"build:docs": "bun run build-docs.ts",
		"test:ws": "bun run test/other/ws-simulation.ts",
		"test:benchmark": "bun run test/benchmark/benchmark.ts",
		"tests": "bun test && bun test:ws -s && bun test:benchmark"
	},
	"devDependencies": {
		"@types/bun": "^1.3.11",
		"arktype": "^2.2.0",
		"bun-plugin-dts": "^0.4.0",
		"marked": "^17.0.5",
		"memoirist": "^0.4.0",
		"oxlint": "^1.57.0",
		"prettier": "^3.8.1",
		"redis": "^5.11.0",
		"ws": "^8.20.0",
		"zod": "^4.3.6"
	},
	"peerDependencies": {
		"memoirist": "^0.4.0",
		"redis": "^5.11.0",
		"typescript": "^6.0.2"
	},
	"peerDependenciesMeta": {
		"memoirist": {
			"optional": true
		},
		"redis": {
			"optional": true
		}
	},
	"dependencies": {
		"@types/ws": "^8.18.1"
	}
}
